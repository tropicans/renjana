# Renjana LMS - Environment Variables
# Copy this file to .env and fill in the values

# ─── Database ─────────────────────────────────────────────
# For Docker: use the service name "postgres" as hostname
DATABASE_URL="postgresql://renjana:renjana_dev@postgres:5432/renjana_db"

# For local dev (outside Docker): use localhost
# DATABASE_URL="postgresql://renjana:renjana_dev@localhost:5432/renjana_db"

# ─── NextAuth ─────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="ganti-dengan-random-string-yang-panjang"
NEXTAUTH_URL="http://localhost:3214"

# ─── App ──────────────────────────────────────────────────
NODE_ENV=production

# ─── DOKU Payment Gateway ─────────────────────────────────
# Supported value: DOKU
NEXT_PUBLIC_PAYMENT_PROVIDER=""
DOKU_API_BASE_URL="https://api-sandbox.doku.com"
DOKU_CLIENT_ID=""
DOKU_SECRET_KEY=""
DOKU_WEBHOOK_URL=""
DOKU_WEBHOOK_TOKEN=""
